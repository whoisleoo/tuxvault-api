# Olá caro leitor, esse aqui é um exemplo de como o .env deve ser composto para que você, sim VOCÊ! utilize o tuxvault com segurança! :D

# App
PORT=8080
APP_URL=https://seudominio.com
NODE_ENV=production

# Database
# Em producao (Docker): DATABASE_URL e construida pelo docker-compose usando DB_PASSWORD
# Em desenvolvimento local (sem Docker): DATABASE_URL direto
DB_PASSWORD=senha_do_banco_aqui
DATABASE_URL=postgresql://tuxvault:senha_do_banco_aqui@localhost:5432/tuxvault

# Session
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=minimo_64_caracteres_aleatorios_aqui

# Samba / Storage
# Em Docker: host.docker.internal
# Em dev local: localhost
SAMBA_HOST=host.docker.internal
SAMBA_SHARE=vault
HOST_SSH_USER=tuxvault-terminal
VAULT_PATH=/data/vault
UPLOAD_MAX_SIZE_GB=15
VAULT_MAX_SIZE_GB=500

# Email (OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_app_password_do_gmail
SMTP_TO=admin@seudominio.com

# Configuráveis
AUDIT_LOG_RETENTION_DAYS=90
SESSION_MAX_AGE_HOURS=8
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_ATTEMPTS=10
OTP_EXPIRY_MINUTES=5
REQUEST_TIMEOUT_MINUTES=30

# Modo desenvolvimento (NUNCA ATIVAR ISSO AQUI EM PROD)
# DEV_MODE=true
# DEV_ADMIN_USERNAME=admin
